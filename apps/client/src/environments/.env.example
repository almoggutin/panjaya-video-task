# Copy this file to .env.development, .env.staging, or .env.production
# and fill in the values for your environment.
# All variables prefixed with VITE_ are exposed to the client bundle.

# Base URL for the FastAPI backend (required)
VITE_API_URL=http://localhost:8000

# Maximum upload size in MB (optional, defaults to 500)
VITE_MAX_UPLOAD_MB=500
VITE_GITHUB_URL=https://github.com/almoggutin/panjaya-video-task
