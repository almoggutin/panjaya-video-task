# Application Configuration
ENVIRONMENT=test
LOG_LEVEL=WARNING
CORS_WHITELIST=[]
API_VERSION=v1

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/panjaya_test

# Redis Configuration
REDIS_URL=redis://localhost:6380/0

# Storage Configuration
S3_ENDPOINT_URL=http://localhost:9100
S3_BUCKET=panjaya-test
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# Auth Configuration
JWT_SECRET=test-secret-that-is-long-enough-for-hmac
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# Upload Configuration
MAX_UPLOAD_BYTES=524288000

# Worker Configuration
WORKER_JOB_TIMEOUT=600
WORKER_MAX_TRIES=3
WORKER_JOB_SECRET=test-worker-secret
